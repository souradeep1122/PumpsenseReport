<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>PUMPSENSE | <%= typeof design !== 'undefined' ? 'Edit' : 'Upload' %> Design</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="<%= logoUrl %>">

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        *{
            box-sizing:border-box;
        }

        body{
            font-family:'Inter',sans-serif;
            background:#f8fafc;
            overflow-x:hidden;
        }

        .fade-in{
            animation:fadeIn .4s ease forwards;
        }

        @keyframes fadeIn{
            from{
                opacity:0;
                transform:translateY(12px);
            }
            to{
                opacity:1;
                transform:translateY(0);
            }
        }

        .glass{
            background:rgba(255,255,255,.82);
            backdrop-filter:blur(14px);
            -webkit-backdrop-filter:blur(14px);
        }

        .dropdown-menu{
            display:none;
            opacity:0;
            transform:translateY(-8px);
            transition:.2s ease;
        }

        .dropdown-menu.show{
            display:block;
            opacity:1;
            transform:translateY(0);
        }

        .input-error{
            border-color:#ef4444 !important;
            background:#fef2f2 !important;
        }

        .error-message{
            display:none;
            color:#ef4444;
            font-size:.72rem;
            font-weight:700;
            margin-top:.35rem;
            letter-spacing:.03em;
        }

        .field-card{
            background:white;
            border:1px solid #e2e8f0;
            border-radius:22px;
            padding:16px;
            transition:.25s ease;
        }

        .field-card:hover{
            border-color:#cbd5e1;
        }

        .input-wrap{
            position:relative;
        }

        .input-wrap i{
            position:absolute;
            left:18px;
            top:50%;
            transform:translateY(-50%);
            color:#94a3b8;
            transition:.2s ease;
        }

        .modern-input{
            width:100%;
            border:1px solid #e2e8f0;
            background:#f8fafc;
            border-radius:16px;
            padding:14px 16px 14px 48px;
            outline:none;
            font-size:.92rem;
            font-weight:600;
            transition:.25s ease;
        }

        .modern-input:focus{
            border-color:#2563eb;
            background:white;
            box-shadow:0 0 0 4px rgba(37,99,235,.1);
        }

        .metric-input{
            padding-left:18px;
            padding-right:72px;
        }

        .unit{
            position:absolute;
            right:14px;
            top:50%;
            transform:translateY(-50%);
            font-size:.65rem;
            font-weight:900;
            letter-spacing:.08em;
            color:#64748b;
            background:white;
            border:1px solid #e2e8f0;
            padding:6px 10px;
            border-radius:10px;
            text-transform:uppercase;
        }

        .section-title{
            display:flex;
            align-items:center;
            gap:12px;
            margin-bottom:20px;
        }

        .section-number{
            width:36px;
            height:36px;
            border-radius:12px;
            background:#dbeafe;
            color:#2563eb;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:.78rem;
            font-weight:900;
        }

        .hero-pattern{
            position:absolute;
            inset:0;
            background-image:
            radial-gradient(circle at top right, rgba(255,255,255,.12), transparent 25%),
            radial-gradient(circle at bottom left, rgba(255,255,255,.08), transparent 20%);
            pointer-events:none;
        }

        .mobile-menu{
            position:absolute;
            top:72px;
            right:16px;
            width:260px;
            background:white;
            border:1px solid #e2e8f0;
            border-radius:22px;
            overflow:hidden;
            box-shadow:0 20px 45px rgba(0,0,0,.12);
            display:none;
            z-index:100;
        }

        .mobile-menu.show{
            display:block;
        }

        .mobile-link{
            display:flex;
            align-items:center;
            gap:14px;
            padding:15px 18px;
            font-size:.92rem;
            font-weight:700;
            color:#334155;
            transition:.2s ease;
        }

        .mobile-link:hover{
            background:#f8fafc;
        }

        @media(max-width:640px){
            .field-card{
                padding:14px;
            }

            .modern-input{
                font-size:.88rem;
            }
        }
    </style>
</head>

<body class="min-h-screen text-slate-900 flex flex-col">

<% const isEdit = typeof design !== 'undefined' && design; %>

<!-- NAVBAR -->
<header class="glass border-b border-slate-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 relative">

        <div class="flex items-center justify-between gap-4">

            <!-- LEFT -->
            <div class="flex items-center gap-3">

                <!-- LOGO -->
                <a href="/view-files" class="flex items-center gap-3 group">

                    <img
                        src="<%= logoUrl %>"
                        alt="Pumpsense Logo"
                        class="h-11 sm:h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
                    >

                    <!-- TEXT RIGHT SIDE -->
                    <div>
                        <h1 class="text-lg sm:text-xl font-black tracking-tight text-slate-900 leading-none">
                            PUMPSENSE
                        </h1>

                        <p class="text-[10px] uppercase tracking-[0.22em] text-slate-500 font-bold mt-1">
                            Fluid Engineering
                        </p>
                    </div>

                </a>
            </div>

            <!-- DESKTOP NAV -->
            <div class="hidden lg:flex items-center gap-5">

                <a href="/view-files"
                   class="text-sm font-semibold text-slate-600 hover:text-blue-600 transition">
                    Performance Reports
                </a>

                <% if (user.role === 'MASTER' || user.role === 'REPORT TEAM') { %>
                    <a href="/upload"
                       class="px-5 py-2.5 bg-slate-900 text-white rounded-xl text-sm font-bold hover:bg-slate-800 transition shadow-sm">
                        Upload Report
                    </a>
                <% } %>

                <!-- PROFILE -->
                <div class="relative">

                    <button id="profileTrigger"
                            class="focus:outline-none transition hover:scale-105 active:scale-95">

                        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-black shadow-lg border-2 border-white">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                    </button>

                    <div id="profileDropdown"
                         class="dropdown-menu absolute right-0 mt-3 w-64 bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden">

                        <div class="p-5 bg-slate-50 border-b border-slate-100">
                            <p class="text-[10px] uppercase tracking-[0.2em] font-black text-slate-400 mb-1">
                                Signed in as
                            </p>

                            <p class="text-sm font-bold truncate text-slate-900">
                                <%= user.username %>
                            </p>
                        </div>

                        <div class="p-2">

                            <div class="flex items-center gap-3 px-3 py-3 rounded-xl bg-blue-50">
                                <i class="fa-solid fa-shield-halved text-blue-500"></i>

                                <div>
                                    <p class="text-[10px] uppercase tracking-wide font-black text-slate-400">
                                        System Role
                                    </p>

                                    <p class="text-xs font-black tracking-wide text-blue-700">
                                        <%= user.role %>
                                    </p>
                                </div>
                            </div>

                            <hr class="my-2 border-slate-100">

                            <a href="/logout"
                               class="flex items-center gap-3 px-3 py-3 rounded-xl text-red-500 hover:bg-red-50 transition">

                                <i class="fa-solid fa-power-off"></i>
                                <span class="text-sm font-bold">Logout Session</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MOBILE MENU BUTTON -->
            <button
                id="mobileMenuBtn"
                class="lg:hidden w-11 h-11 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-700 shadow-sm"
            >
                <i class="fa-solid fa-bars text-lg"></i>
            </button>
        </div>

        <!-- MOBILE MENU -->
        <div id="mobileMenu" class="mobile-menu lg:hidden">

            <a href="/view-files" class="mobile-link">
                <i class="fa-solid fa-chart-line text-blue-600 w-5"></i>
                <span>Performance Report</span>
            </a>

            <a href="/upload" class="mobile-link">
                <i class="fa-solid fa-upload text-blue-600 w-5"></i>
                <span>Upload Report</span>
            </a>

            <a href="/manage-users" class="mobile-link">
                <i class="fa-solid fa-users-gear text-blue-600 w-5"></i>
                <span>Manage User</span>
            </a>

            
            <a href="/logout" class="mobile-link text-red-500">
                <i class="fa-solid fa-power-off w-5"></i>
                <span>Logout</span>
            </a>

        </div>
    </div>
</header>

<!-- MAIN -->
<main class="flex-grow px-4 sm:px-6 py-6 sm:py-8">

    <div class="max-w-6xl mx-auto fade-in">

        <div class="bg-white rounded-[30px] shadow-2xl shadow-slate-200/60 overflow-hidden border border-slate-100">

            <!-- HERO -->
            <div class="relative overflow-hidden bg-gradient-to-br from-blue-600 to-blue-800 px-6 sm:px-10 py-7 sm:py-8">

                <div class="hero-pattern"></div>

                <div class="relative z-10">

                    <h2 class="text-2xl sm:text-4xl font-black text-white leading-tight tracking-tight">
                        <%= isEdit ? 'Edit Design Specification' : 'Upload Design Specification' %>
                    </h2>

                </div>
            </div>

            <!-- ALERTS -->
            <div id="msgContainer">

                <% if (typeof message !== 'undefined' && message && message.length > 0) { %>

                    <div class="mx-6 sm:mx-10 mt-6 bg-red-50 border border-red-100 rounded-2xl p-5">
                        <div class="flex items-start gap-3">

                            <i class="fa-solid fa-circle-exclamation text-red-500 mt-0.5"></i>

                            <div>
                                <p class="text-sm font-black text-red-700 uppercase tracking-wide">
                                    Action Required
                                </p>

                                <p class="text-xs text-red-600 mt-1 leading-relaxed">
                                    <%= message %>
                                </p>
                            </div>
                        </div>
                    </div>

                <% } %>

                <div id="validation-alert"
                     class="hidden mx-6 sm:mx-10 mt-6 bg-amber-50 border border-amber-100 rounded-2xl p-5">

                    <div class="flex items-start gap-3">

                        <i class="fa-solid fa-triangle-exclamation text-amber-600 mt-0.5"></i>

                        <div>
                            <p class="text-sm font-black uppercase tracking-wide text-amber-800">
                                Duplicate Identity
                            </p>

                            <p id="validation-text"
                               class="text-xs font-medium mt-1 text-amber-700 leading-relaxed"></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FORM -->
            <form
                id="designForm"
                action="<%= isEdit ? '/update-design/' + design._id : '/upload-design' %>"
                method="POST"
                class="p-6 sm:p-10 space-y-8"
            >

                <!-- PUMP IDENTITY -->
                <section>

                    <div class="section-title">
                        <div class="section-number">01</div>

                        <div>
                            <h3 class="text-sm font-black uppercase tracking-[0.2em] text-slate-400">
                                Pump Identity
                            </h3>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

                        <!-- MODEL -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Pump Model
                            </label>

                            <div class="input-wrap">

                                <input
                                    type="text"
                                    name="pumpModel"
                                    id="pumpModel"
                                    required
                                    value="<%= isEdit ? design.pumpModel : '' %>"
                                    placeholder="Enter Model"
                                    class="modern-input"
                                >

                                <i class="fa-solid fa-tag"></i>
                            </div>

                            <p id="model-error" class="error-message">
                                <i class="fa-solid fa-circle-xmark mr-1"></i>
                                Combination already exists
                            </p>
                        </div>

                        <!-- SERIAL -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Serial Number
                            </label>

                            <div class="input-wrap">

                                <input
                                    type="text"
                                    name="serialNo"
                                    id="serialNo"
                                    required
                                    value="<%= isEdit ? design.serialNo : '' %>"
                                    placeholder="Enter Serial"
                                    class="modern-input"
                                >

                                <i class="fa-solid fa-hashtag"></i>
                            </div>

                            <p id="serial-error" class="error-message">
                                <i class="fa-solid fa-circle-xmark mr-1"></i>
                                Identity must be unique
                            </p>
                        </div>

                    </div>
                </section>

                <!-- TECHNICAL -->
                <section>

                    <div class="section-title">

                        <div class="section-number">02</div>

                        <div>
                            <h3 class="text-sm font-black uppercase tracking-[0.2em] text-slate-400">
                                Technical Parameters
                            </h3>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                        <!-- DISCHARGE -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Discharge Rate
                            </label>

                            <div class="relative">

                                <input
                                    type="number"
                                    step="0.01"
                                    name="discharge"
                                    min="0"
                                    required
                                    value="<%= isEdit ? design.discharge : '' %>"
                                    placeholder="0.00"
                                    class="modern-input metric-input"
                                >

                                <span class="unit">m³/hr</span>
                            </div>
                        </div>

                        <!-- POWER -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Power Input
                            </label>

                            <div class="relative">

                                <input
                                    type="number"
                                    step="0.01"
                                    name="power"
                                    min="0"
                                    required
                                    value="<%= isEdit ? design.power : '' %>"
                                    placeholder="0.00"
                                    class="modern-input metric-input"
                                >

                                <span class="unit">KW</span>
                            </div>
                        </div>

                        <!-- EFFICIENCY -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Efficiency
                            </label>

                            <div class="relative">

                                <input
                                    type="number"
                                    step="0.1"
                                    name="efficiency"
                                    min="0"
                                    required
                                    value="<%= isEdit ? design.efficiency : '' %>"
                                    placeholder="0.0"
                                    class="modern-input metric-input"
                                >

                                <span class="unit">%</span>
                            </div>
                        </div>

                        <!-- HEAD -->
                        <div class="field-card">

                            <label class="block text-xs font-black uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Total Dynamic Head
                            </label>

                            <div class="relative">

                                <input
                                    type="number"
                                    step="0.01"
                                    name="totalHead"
                                    min="0"
                                    required
                                    value="<%= isEdit ? design.totalHead : '' %>"
                                    placeholder="0.00"
                                    class="modern-input metric-input"
                                >

                                <span class="unit">MWC</span>
                            </div>
                        </div>

                    </div>
                </section>

                <!-- ACTIONS -->
                <section class="pt-2">

                    <div class="flex flex-col lg:flex-row gap-4 lg:items-center lg:justify-between">

                        <button
                            type="submit"
                            id="submitBtn"
                            class="w-full lg:flex-1 bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-2xl transition-all shadow-xl shadow-blue-200 hover:shadow-2xl hover:shadow-blue-300 active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-3"
                        >

                            <i class="fa-solid fa-floppy-disk text-lg" id="btnIcon"></i>

                            <span id="btnText" class="tracking-wide text-sm">
                                Save
                            </span>

                        </button>

                        <div class="grid grid-cols-2 sm:flex gap-4 w-full lg:w-auto">

                            <% if (isEdit && user.role === 'MASTER') { %>

                                <button
                                    type="button"
                                    onclick="handleDelete('<%= design._id %>')"
                                    class="px-6 py-4 rounded-2xl bg-red-50 border border-red-100 text-red-600 hover:bg-red-100 transition font-bold flex items-center justify-center gap-2"
                                >
                                    <i class="fa-solid fa-trash-can"></i>
                                    <span>Delete</span>
                                </button>

                            <% } %>

                            <a
                                href="/view-files"
                                class="px-8 py-4 rounded-2xl bg-slate-100 hover:bg-slate-200 text-slate-600 transition font-bold flex items-center justify-center"
                            >
                                Cancel
                            </a>

                        </div>

                    </div>
                </section>

            </form>
        </div>

        <!-- FOOTER -->
        <footer class="py-8 flex flex-col items-center gap-4">

            <div class="flex items-center gap-3 text-slate-300">
                <div class="h-px w-10 bg-slate-200"></div>
                <i class="fa-solid fa-droplet text-xs opacity-50"></i>
                <div class="h-px w-10 bg-slate-200"></div>
            </div>

            <p class="text-[10px] font-black uppercase tracking-[0.35em] text-slate-400 text-center">
                © 2026 PumpSense Engineering Systems
            </p>
        </footer>

    </div>
</main>

<script>
    /**
     * LOGIC PRESERVATION
     */

    const form = document.getElementById('designForm');
    const pumpModelInput = document.getElementById('pumpModel');
    const serialNoInput = document.getElementById('serialNo');
    const submitBtn = document.getElementById('submitBtn');
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    const validationAlert = document.getElementById('validation-alert');
    const validationText = document.getElementById('validation-text');
    const profileTrigger = document.getElementById('profileTrigger');
    const profileDropdown = document.getElementById('profileDropdown');

    const isEditMode = <%= isEdit %>;

    const originalModel = "<%= isEdit && typeof design !== 'undefined' ? design.pumpModel : '' %>".toLowerCase().trim();

    const originalSerial = "<%= isEdit && typeof design !== 'undefined' ? design.serialNo : '' %>".toLowerCase().trim();

    profileTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        profileDropdown.classList.toggle('show');
    });

    window.addEventListener('click', () => {
        if (profileDropdown.classList.contains('show')) {
            profileDropdown.classList.remove('show');
        }
    });

    async function handleDelete(id) {

        if (!confirm("Confirm permanent deletion of this design?")) return;

        try {

            const response = await fetch(`/delete-design/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = '/view-files';
            } else {
                alert("Delete failed: " + result.message);
            }

        } catch (err) {

            alert("Connection error during deletion.");
        }
    }

    async function checkPairUniqueness(model, serial) {

        const m = model.trim();
        const s = serial.trim();

        if (!m || !s) return true;

        if (
            isEditMode &&
            m.toLowerCase() === originalModel &&
            s.toLowerCase() === originalSerial
        ) {
            return true;
        }

        try {

            const response = await fetch(
                `/validate-design-identity?model=${encodeURIComponent(m)}&serial=${encodeURIComponent(s)}`
            );

            const data = await response.json();

            return data.isUnique;

        } catch (err) {

            console.warn("Server validation failed", err);

            return true;
        }
    }

    async function runValidation() {

        const mValue = pumpModelInput.value.trim();
        const sValue = serialNoInput.value.trim();

        if (!mValue || !sValue) return true;

        const isUnique = await checkPairUniqueness(mValue, sValue);

        if (!isUnique) {

            pumpModelInput.classList.add('input-error');
            serialNoInput.classList.add('input-error');

            document.getElementById('model-error').style.display = 'block';
            document.getElementById('serial-error').style.display = 'block';

            validationAlert.classList.remove('hidden');

            validationText.innerText =
                `The combination of Model "${mValue}" and Serial "${sValue}" already exists in the system.`;

            return false;

        } else {

            clearErrors();

            return true;
        }
    }

    function clearErrors() {

        pumpModelInput.classList.remove('input-error');
        serialNoInput.classList.remove('input-error');

        document.getElementById('model-error').style.display = 'none';
        document.getElementById('serial-error').style.display = 'none';

        validationAlert.classList.add('hidden');
    }

    pumpModelInput.addEventListener('blur', runValidation);
    serialNoInput.addEventListener('blur', runValidation);

    [pumpModelInput, serialNoInput].forEach(input => {
        input.addEventListener('input', clearErrors);
    });

    form.addEventListener('submit', async (e) => {

        e.preventDefault();

        submitBtn.disabled = true;

        const originalBtnHtml = btnText.innerHTML;

        btnText.innerText = 'Verifying Identity...';

        btnIcon.className = 'fa-solid fa-spinner fa-spin';

        const isValid = await runValidation();

        if (isValid) {

            btnText.innerText = 'Saving...';

            form.submit();

        } else {

            submitBtn.disabled = false;

            btnText.innerHTML = originalBtnHtml;

            btnIcon.className = 'fa-solid fa-floppy-disk text-lg';

            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        }
    });

    /**
     * MOBILE MENU
     */

    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');

    mobileMenuBtn.addEventListener('click', (e) => {

        e.stopPropagation();

        mobileMenu.classList.toggle('show');
    });

    window.addEventListener('click', (e) => {

        if (
            mobileMenu &&
            !mobileMenu.contains(e.target) &&
            !mobileMenuBtn.contains(e.target)
        ) {
            mobileMenu.classList.remove('show');
        }
    });
</script>

</body>
</html>