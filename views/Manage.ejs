<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users | PUMPSENSE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="<%= logoUrl %>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .fade-in { animation: fadeIn 0.3s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .custom-scrollbar::-webkit-scrollbar { height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        
        .dropdown-menu {
            display: none;
            opacity: 0;
            transform: translateY(-10px);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }
        .dropdown-menu.show {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        /* Modal styling to match dashboard aesthetic */
        #deleteModal {
            backdrop-filter: blur(4px);
            background: rgba(15, 23, 42, 0.4);
        }

        .role-badge {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Mobile Table Transformation */
        @media (max-width: 767px) {
            table, thead, tbody, th, td, tr { 
                display: block; 
            }
            thead { 
                display: none; 
            }
            tbody {
                background: transparent !important;
            }
            tr {
                margin-bottom: 0.5rem;
                border: 1px solid rgba(226, 232, 240, 0.4);
                border-radius: 12px;
                padding: 0.25rem;
                background: rgba(255, 255, 255, 0.4) !important;
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }
            td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.25rem 0.6rem !important;
                border: none !important;
                text-align: right;
                min-height: 28px;
                font-size: 0.75rem !important;
            }
            td::before {
                content: attr(data-label);
                font-weight: 800;
                text-transform: uppercase;
                font-size: 0.6rem;
                color: #64748b;
                text-align: left;
                margin-right: 1rem;
            }
            /* Action cell separation */
            td:last-child {
                border-top: 1px solid rgba(241, 245, 249, 0.4) !important;
                margin-top: 0.15rem;
                padding-top: 0.4rem !important;
            }
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 min-h-screen flex flex-col font-sans">

    <!-- Header (Consistent with Dashboard) -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <div class="flex items-center space-x-3 md:space-x-4">
                <img src="<%= logoUrl %>" alt="Pumpsense Logo" class="h-10 md:h-12 w-auto block object-contain">
                <div class="border-l border-gray-200 pl-3 md:pl-4">
                    <h1 class="text-lg md:text-xl font-bold tracking-tight text-slate-900 uppercase leading-none">Pumpsense</h1>
                    <p class="text-[9px] md:text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Fluid Engineering</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <nav class="hidden md:flex items-center space-x-6 mr-2">
                    <a href="/view-files" class="text-sm font-bold text-blue-600 hover:text-blue-800 transition-colors">
                        <i class="fa-solid fa-chart-line mr-1"></i> Dashboard
                    </a>
                </nav>

                <div class="relative hidden md:block">
                    <button id="profileTrigger" class="focus:outline-none transition-transform hover:scale-105 active:scale-95">
                        <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold shadow-md border-2 border-white">
                            <%= currentUser.username.charAt(0).toUpperCase() %>
                        </div>
                    </button>
                    <div id="profileDropdown" class="dropdown-menu absolute right-0 mt-3 w-64 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                        <div class="p-4 bg-gray-50/50 border-b border-gray-100 text-center">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Signed in as</p>
                            <p class="text-sm font-bold text-slate-900 truncate"><%= currentUser.username %></p>
                        </div>
                        <div class="p-2">
                            <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-blue-50/50">
                                <i class="fa-solid fa-user-shield text-blue-500 w-4"></i>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">System Role</p>
                                    <p class="text-xs font-black text-blue-600"><%= currentUser.role %></p>
                                </div>
                            </div>
                            
                            <hr class="my-2 border-gray-100">
                            <a href="/logout" class="flex items-center gap-3 px-3 py-3 rounded-lg text-red-500 hover:bg-red-50 transition-colors">
                                <i class="fa-solid fa-right-from-bracket w-4"></i>
                                <span class="text-sm font-bold">Logout</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col items-center p-2 md:p-4">
        <div class="w-full max-w-[98%] fade-in mt-2 md:mt-4">
            
            <!-- Page Identity -->
            <div class="mb-6 flex justify-between items-end px-2 md:px-0">
                <div>
                    <h2 class="text-xl md:text-2xl font-bold text-slate-900">User Access Management</h2>
                    <p class="text-xs md:text-sm text-slate-500 mt-1">Control system privileges and manage platform contributors.</p>
                </div>
                <div id="userCountBadge" class="bg-white border border-slate-200 px-3 md:px-4 py-1.5 md:py-2 rounded-xl shadow-sm text-xs md:text-sm font-bold text-slate-600 flex items-center gap-2">
                    <i class="fa-solid fa-users text-blue-500"></i>
                    <span id="userCountLabel">0 Users</span>
                </div>
            </div>

            <!-- Alerts -->
            <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
                <div class="mx-2 md:mx-0 mb-6 p-4 bg-green-50 border border-green-100 rounded-xl text-green-700 text-sm font-medium flex items-center gap-3">
                    <i class="fa-solid fa-circle-check"></i> <%= success %>
                </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <div class="mx-2 md:mx-0 mb-6 p-4 bg-red-50 border border-red-100 rounded-xl text-red-700 text-sm font-medium flex items-center gap-3">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
                </div>
            <% } %>

            <!-- Users Container -->
            <div class="md:bg-white bg-transparent rounded-xl md:rounded-2xl md:shadow-xl overflow-hidden md:border border-slate-100">
                <div class="overflow-x-auto min-h-[400px] p-2 md:p-0 custom-scrollbar">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="py-4 pl-6 pr-3 text-left text-xs font-black text-slate-500 uppercase tracking-widest border-b">User Identification</th>
                                <th class="px-3 py-4 text-left text-xs font-black text-slate-500 uppercase tracking-widest border-b">Privilege Control</th>
                                <th class="relative py-4 pr-6 text-right text-xs font-black text-slate-500 uppercase tracking-widest border-b">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            <% if (users && users.length > 0) {
                                users.forEach(function(user) {
                                    const role = user.role || 'USER';
                                    const isMe = user._id.toString() === currentUser._id.toString();
                            %>
                            <tr class="md:hover:bg-blue-50/30 transition-colors group">
                                <td data-label="User Identification" class="py-4 md:pl-6 pr-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 md:w-9 md:h-9 bg-slate-100 text-slate-500 rounded-full flex items-center justify-center font-bold text-xs md:text-sm border border-slate-200">
                                            <%= user.username.charAt(0).toUpperCase() %>
                                        </div>
                                        <div class="text-left">
                                            <p class="text-sm font-bold text-slate-900"><%= user.username %></p>
                                            <% if (isMe) { %>
                                                <span class="text-[9px] font-black uppercase text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded">You</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Privilege Control" class="px-3 py-4">
                                    <form action="/update-user-role/<%= user._id %>" method="POST" class="flex items-center gap-2 justify-end md:justify-start">
                                        <select name="role" class="bg-slate-50 border border-slate-200 text-slate-700 text-xs font-bold rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full max-w-[140px] md:max-w-[160px] p-1.5 md:p-2 cursor-pointer">
                                            <% availableRoles.forEach(function(r) { %>
                                                <option value="<%= r %>" <%= user.role === r ? 'selected' : '' %>><%= r %></option>
                                            <% }); %>
                                        </select>
                                        <button type="submit" class="w-7 h-7 md:w-8 md:h-8 flex items-center justify-center rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-all shadow-sm" title="Save Role">
                                            <i class="fa-solid fa-check text-[10px] md:text-xs"></i>
                                        </button>
                                    </form>
                                </td>
                                <td data-label="Actions" class="px-6 py-4 text-right">
                                    <% if (!isMe) { %>
                                        <button onclick="confirmDelete('<%= user._id %>', '<%= user.username %>')" class="text-slate-300 hover:text-red-600 p-2 transition-colors">
                                            <i class="fa-solid fa-trash-can text-sm"></i>
                                        </button>
                                    <% } else { %>
                                        <span class="text-[10px] font-bold text-slate-300 uppercase tracking-tighter">System Admin</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); } else { %>
                                <tr>
                                    <td colspan="3" class="py-20 text-center">
                                        <div class="flex flex-col items-center gap-3 text-slate-300">
                                            <i class="fa-solid fa-users-slash text-3xl"></i>
                                            <span class="text-sm font-semibold text-slate-400">No users found</span>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="p-4 bg-gray-50/50 border-t border-slate-100 hidden md:flex justify-between items-center">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Admin Control Panel</span>
                    <span class="text-[10px] uppercase font-black text-slate-300 tracking-widest">PumpSense Systems v2.0</span>
                </div>
            </div>
        </div>
    </main>

    <!-- Delete Modal (Dashboard Style) -->
    <div id="deleteModal" class="fixed inset-0 z-[1000] hidden items-center justify-center p-4">
        <div class="bg-white rounded-3xl max-w-md w-full p-8 shadow-2xl border border-slate-100 animate-fade-in">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
                <i class="fa-solid fa-user-minus"></i>
            </div>
            <h3 class="text-xl font-bold text-slate-900 text-center mb-2">Delete User Account</h3>
            <p class="text-slate-500 text-center text-sm mb-8">
                Are you sure you want to remove <strong id="targetUsername" class="text-slate-900"></strong>? This user will lose all access immediately.
            </p>
            <div class="flex gap-3">
                <button onclick="closeModal()" class="flex-1 py-3 rounded-xl bg-slate-100 text-slate-600 font-bold text-sm hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
                <button id="confirmDeleteBtn" class="flex-1 py-3 rounded-xl bg-red-600 text-white font-bold text-sm hover:bg-red-700 shadow-lg shadow-red-200 transition-all">
                    Delete User
                </button>
            </div>
        </div>
    </div>

    <footer class="bg-white border-t border-slate-100 py-4 mt-auto">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-[9px] md:text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                &copy; <span id="yr"></span> PUMPSENSE FLUID ENGINEERING PVT LTD — All rights reserved
            </p>
        </div>
    </footer>

    <script>
        document.getElementById('yr').textContent = new Date().getFullYear();

        // UI Interactions
        document.getElementById('profileTrigger').onclick = (e) => {
            e.stopPropagation();
            document.getElementById('profileDropdown').classList.toggle('show');
        };
        window.onclick = () => {
            document.getElementById('profileDropdown').classList.remove('show');
        };

        // User count logic
        const userRows = document.querySelectorAll('tbody tr:not(:has(.fa-users-slash))');
        document.getElementById('userCountLabel').textContent = userRows.length + ' ' + (userRows.length === 1 ? 'User' : 'Users');

        // Deletion Logic
        let deleteId = null;

        function confirmDelete(id, username) {
            deleteId = id;
            document.getElementById('targetUsername').innerText = username;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('deleteModal').style.display = 'none';
            deleteId = null;
        }

        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
            if (!deleteId) return;
            const btn = document.getElementById('confirmDeleteBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Processing...';
            btn.disabled = true;

            try {
                const res = await fetch(`/delete-user/${deleteId}`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Failed to delete user.');
                    closeModal();
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                console.error('Delete error:', err);
                closeModal();
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>