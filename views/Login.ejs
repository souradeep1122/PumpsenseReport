<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login & Registration | PUMPSENSE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="<%= logoUrl %>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        body { font-family: 'Inter', sans-serif; }

        .fade-in { animation: fadeIn 0.5s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Toggle Login/Register logic */
        #authToggle { display: none; }
        .register-form { display: none; }
        #authToggle:checked ~ .form-container .register-form { display: block; }
        #authToggle:checked ~ .form-container .login-form { display: none; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        #successPopup {
            backdrop-filter: blur(4px);
            background: rgba(15, 23, 42, 0.4);
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 min-h-screen flex flex-col">

    <!-- ══ SUCCESS POPUP ══ -->
    <div id="successPopup" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4">
        <div class="bg-white rounded-3xl text-center max-w-sm w-full p-8 shadow-2xl fade-in border border-slate-100">
            <div class="w-16 h-16 bg-green-50 text-green-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-4">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <h3 class="text-slate-900 text-xl font-bold mb-2">Account Created</h3>
            <p id="successMsgText" class="text-slate-500 text-sm leading-relaxed mb-6"></p>
            <button onclick="closePopup()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-200">
                Proceed to Login
            </button>
        </div>
    </div>

    <!-- ── MAIN WRAPPER ── -->
    <div class="flex flex-1 flex-col md:flex-row">

        <!-- LEFT PANEL: Visual & Branding -->
        <div class="relative w-full md:w-1/2 lg:w-[45%] bg-slate-900 flex flex-col justify-center px-8 py-12 md:px-16 lg:px-24 overflow-hidden text-white">
            <div class="absolute top-[-10%] left-[-10%] w-64 h-64 bg-blue-600 rounded-full blur-[120px] opacity-20"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-64 h-64 bg-blue-400 rounded-full blur-[120px] opacity-10"></div>

            <div class="relative z-10">
                <div class="flex items-center gap-4 mb-10">
                    <div class="h-14 w-14 bg-white p-2 rounded-2xl shadow-xl flex items-center justify-center">
                        <img src="<%= logoUrl %>" alt="Pumpsense" class="max-h-full max-w-full object-contain" onerror="this.parentElement.innerHTML='<i class=\'fa-solid fa-droplet text-blue-600 text-2xl\'></i>'">
                    </div>
                    <div>
                        <h1 class="text-2xl font-black tracking-tighter uppercase leading-none">Pumpsense</h1>
                        <p class="text-[10px] text-blue-400 font-bold uppercase tracking-[0.3em] mt-1">Fluid Engineering</p>
                    </div>
                </div>

                <h2 class="text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight mb-6">
                    Analyze. Compare. <br/>
                    <span class="text-blue-500">Optimize Performance.</span>
                </h2>
                
                <p class="text-slate-400 text-lg leading-relaxed max-w-md">
                    Access the unified portal of pumpsense fluid engineering's performance reports and design specifications.
                </p>
            </div>

            <div class="absolute bottom-8 left-8 right-8 md:left-16 lg:left-24 flex items-center gap-2">
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">© Pumpsense Systems v2.0</span>
            </div>
        </div>

        <!-- RIGHT PANEL: Forms -->
        <div class="w-full md:w-1/2 lg:w-[55%] flex items-center justify-center p-6 md:p-12 bg-white">
            
            <input type="checkbox" id="authToggle" />

            <div class="form-container w-full max-w-[440px] fade-in">
                
                <!-- ── LOGIN FORM ── -->
                <div class="login-form">
                    <div class="mb-8">
                        <h3 class="text-3xl font-bold text-slate-900 mb-2">Welcome Back</h3>
                        <p class="text-slate-500">Sign in to manage your fluid engineering data.</p>
                    </div>

                    <% if (typeof message !== 'undefined' && message && message.length > 0) { %>
                        <div class="bg-red-50 border border-red-100 text-red-600 p-4 rounded-xl text-sm font-medium mb-6 flex items-center gap-3">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <%= message %>
                        </div>
                    <% } %>

                    <form action="/login" method="POST" class="space-y-5">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Username or Email</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
                                    <i class="fa-solid fa-user text-sm"></i>
                                </span>
                                <input type="text" name="username" placeholder="Enter username" required
                                    class="w-full h-12 pl-11 pr-4 bg-gray-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Password</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
                                    <i class="fa-solid fa-lock text-sm"></i>
                                </span>
                                <input type="password" name="password" placeholder="••••••••" required
                                    class="w-full h-12 pl-11 pr-4 bg-gray-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
                            </div>
                        </div>

                        <button type="submit" class="w-full h-12 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-blue-100 active:scale-[0.98]">
                            Sign In
                        </button>
                    </form>

                    <div class="mt-8 text-center">
                        <p class="text-sm text-slate-500">
                            New to the portal? 
                            <label for="authToggle" class="text-blue-600 font-bold cursor-pointer hover:underline ml-1">Create an account</label>
                        </p>
                    </div>
                </div>

                <!-- ── REGISTRATION FORM ── -->
                <div class="register-form">
                    <div class="mb-6">
                        <h3 class="text-3xl font-bold text-slate-900 mb-2">Create Account</h3>
                        <p class="text-slate-500 text-sm">Join the industrial monitoring ecosystem.</p>
                    </div>

                    <div class="bg-blue-50 border border-blue-100 p-4 rounded-xl mb-6">
                        <p class="text-[11px] text-blue-700 font-semibold leading-relaxed">
                            <i class="fa-solid fa-circle-info mr-1"></i> Use your corporate email to register. Master roles are assigned based on company whitelist.
                        </p>
                    </div>

                    <form action="/register" method="POST" id="regForm" class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Company Email</label>
                            <input type="text" name="username" placeholder="name@company.com" required
                                class="w-full h-12 px-4 bg-gray-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Create Password</label>
                            <input type="password" name="password" id="regPassword" placeholder="Minimum 8 characters" required
                                class="w-full h-12 px-4 bg-gray-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Confirm Password</label>
                            <input type="password" name="confirmPassword" id="regConfirmPassword" placeholder="Repeat password" required
                                class="w-full h-12 px-4 bg-gray-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
                        </div>

                        <button type="submit" class="w-full h-12 bg-slate-900 hover:bg-black text-white font-bold rounded-xl transition-all shadow-lg shadow-slate-200 active:scale-[0.98]">
                            Register Account
                        </button>
                    </form>

                    <div class="mt-8 text-center">
                        <p class="text-sm text-slate-500">
                            Already have an account? 
                            <label for="authToggle" class="text-blue-600 font-bold cursor-pointer hover:underline ml-1">Sign in instead</label>
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const successMsg = "<%= (typeof success !== 'undefined' && success.length > 0) ? success : '' %>";
            if (successMsg.trim() !== "") {
                const popup = document.getElementById('successPopup');
                const text = document.getElementById('successMsgText');
                if (popup && text) {
                    text.innerText = successMsg;
                    popup.style.display = 'flex';
                }
            }

            const regForm = document.getElementById('regForm');
            if (regForm) {
                regForm.addEventListener('submit', function (e) {
                    const username = regForm.username.value;
                    const pw = document.getElementById('regPassword').value;
                    const cpw = document.getElementById('regConfirmPassword').value;

                    let errorMsg = "";

                    // Updated logic: Check for @ and .com in username
                    if (!username.includes('@') || !username.toLowerCase().includes('.com')) {
                        errorMsg = "Username must contain '@' and '.com'!";
                    } 
                    // Updated logic: Password at least 8 characters
                    else if (pw.length < 8) {
                        errorMsg = "Password must be at least 8 characters long!";
                    } 
                    else if (pw !== cpw) {
                        errorMsg = "Passwords do not match!";
                    }

                    if (errorMsg) {
                        e.preventDefault();
                        const msg = document.createElement('div');
                        msg.className = "fixed top-4 left-1/2 -translate-x-1/2 bg-red-600 text-white px-6 py-3 rounded-xl shadow-2xl z-[3000] fade-in font-bold text-sm text-center";
                        msg.innerHTML = '<i class="fa-solid fa-triangle-exclamation mr-2"></i> ' + errorMsg;
                        document.body.appendChild(msg);
                        setTimeout(() => msg.remove(), 3000);
                    }
                });
            }
        });

        function closePopup() {
            document.getElementById('successPopup').style.display = 'none';
            document.getElementById('authToggle').checked = false;
        }
    </script>
</body>
</html>